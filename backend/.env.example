# Copy to .env and set for production (or local overrides).
# Django
DJANGO_SECRET_KEY=your-secret-key-at-least-50-chars
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com

# Database (optional). If set, Postgres is used; otherwise SQLite.
# Required for Vercel; recommended for Railway/Render.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# CORS (comma-separated origins; required when DEBUG=false)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Email (for password reset). If unset, reset codes are printed to console (dev only).
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-smtp-user
# EMAIL_HOST_PASSWORD=your-smtp-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
